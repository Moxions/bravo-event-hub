rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function hasProfile() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isOrganizer() {
      return hasProfile() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'organizer';
    }

    function isEventOwner(eventId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/events/$(eventId)) &&
        get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid;
    }

    // Users can create and manage only their own profile.
    match /users/{userId} {
      allow create: if isSelf(userId);
      allow read, update, delete: if isSelf(userId);
    }

    // Events are publicly readable. Only organizer owners can create/update/delete.
    match /events/{eventId} {
      allow read: if true;
      allow create: if isOrganizer() &&
        request.resource.data.organizerId == request.auth.uid;
      allow update, delete: if isOrganizer() &&
        resource.data.organizerId == request.auth.uid;
    }

    // Registrations are private to attendee and event owner.
    match /registrations/{registrationId} {
      allow read: if signedIn() &&
        (resource.data.userId == request.auth.uid ||
         isEventOwner(resource.data.eventId));

      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid &&
        exists(/databases/$(database)/documents/events/$(request.resource.data.eventId));

      allow delete: if signedIn() &&
        (resource.data.userId == request.auth.uid ||
         isEventOwner(resource.data.eventId));

      allow update: if false;
    }
  }
}
