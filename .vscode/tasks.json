		{
			"label": "Clean install dependencies",
			"type": "shell",
			"command": "rm -rf node_modules package-lock.json && npm install",
			"group": "build"
		},
		{
			"label": "Clean install dependencies (PowerShell)",
			"type": "shell",
			"command": "Remove-Item -Recurse -Force node_modules; Remove-Item -Force package-lock.json; npm install",
			"group": "build"
		},
		{
			"label": "Install dependencies (npm)",
			"type": "shell",
			"command": "npm install",
			"group": "build"
		},
		{
			"label": "Force delete node_modules and lock file (Windows)",
			"type": "shell",
			"command": "rd /s /q node_modules & del /f /q package-lock.json",
			"group": "build"
		},
		{
			"label": "Force delete node_modules and lock file (PowerShell)",
			"type": "shell",
			"command": "Remove-Item -Recurse -Force .\\node_modules; Remove-Item -Force .\\package-lock.json",
			"group": "build"
		}
	]
}